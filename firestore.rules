rules_version = '2';

// v2 規則：多寢室(多租戶)架構。個人身分 = Firebase Auth (email/password) 的 uid，
// 不再需要 v1 那套「先比對 PIN 再綁定匿名 uid」的邏輯，簡單很多。
// 寢室密碼一樣是客戶端直接比對(跟 v1 PIN 同等級的簡化)，信任小圈子場景，之後如需加強可換 Cloud Functions。

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function dormData(dormId) {
      return get(/databases/$(database)/documents/dorms/$(dormId)).data;
    }

    // 舊寢室文件可能沒有 visitorUids 欄位(這個功能上線前就建立的)，統一當作空陣列處理
    function existingVisitorUids(data) {
      return ('visitorUids' in data) ? data.visitorUids : [];
    }

    // 正式室友(memberUids，占用人數上限)跟訪客(visitorUids，不占名額、只能待客廳)
    // 都算是「這個寢室的人」，讀取/互動權限一視同仁，差別在 dorms 更新規則跟前端畫面上。
    function isDormMember(dormId) {
      return isSignedIn() && (
        request.auth.uid in dormData(dormId).memberUids ||
        request.auth.uid in existingVisitorUids(dormData(dormId))
      );
    }

    match /accounts/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    match /dorms/{dormId} {
      // 要能用寢室代碼查詢加入，所以已登入者都能讀（密碼欄位本來就是客戶端比對的簡化設計）
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;

      // 三種允許的更新：
      // (a) 寢室主人可以改任何欄位
      // (b) 已註冊(非訪客帳號)的人可以把「自己」加進 memberUids —— 正式室友，占人數上限
      // (c) 任何登入的人(含訪客帳號)可以把「自己」加進 visitorUids —— 訪客，不占名額、不能動人數上限相關欄位
      // 兩種情況都不能動 ownerUid / dormCode / capacity，且不能重複加入
      allow update: if isSignedIn() && (
        resource.data.ownerUid == request.auth.uid ||
        (
          request.auth.token.firebase.sign_in_provider != "anonymous" &&
          request.auth.uid in request.resource.data.memberUids &&
          !(request.auth.uid in resource.data.memberUids) &&
          request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1 &&
          resource.data.memberUids.size() < resource.data.capacity &&
          existingVisitorUids(request.resource.data) == existingVisitorUids(resource.data) &&
          request.resource.data.ownerUid == resource.data.ownerUid &&
          request.resource.data.dormCode == resource.data.dormCode &&
          request.resource.data.capacity == resource.data.capacity
        ) ||
        (
          request.auth.uid in request.resource.data.visitorUids &&
          !(request.auth.uid in existingVisitorUids(resource.data)) &&
          request.resource.data.visitorUids.size() == existingVisitorUids(resource.data).size() + 1 &&
          request.resource.data.memberUids == resource.data.memberUids &&
          request.resource.data.ownerUid == resource.data.ownerUid &&
          request.resource.data.dormCode == resource.data.dormCode &&
          request.resource.data.capacity == resource.data.capacity
        )
      );

      match /members/{uid} {
        allow read, write: if isDormMember(dormId);
      }

      match /rooms/{roomId} {
        allow read: if isDormMember(dormId);
        allow create: if isDormMember(dormId) &&
          (request.resource.data.ownerUid == request.auth.uid || request.resource.data.type == "common");
        allow update: if isDormMember(dormId) && resource.data.ownerUid == request.auth.uid;

        match /knocks/{requesterUid} {
          allow read: if isDormMember(dormId);
          // 房主可以改任何一筆的狀態(同意/拒絕)；敲門者只能把自己那筆設回 pending(=重新敲門)
          allow create, update: if isDormMember(dormId) && (
            get(/databases/$(database)/documents/dorms/$(dormId)/rooms/$(roomId)).data.ownerUid == request.auth.uid ||
            (requesterUid == request.auth.uid && request.resource.data.status == "pending")
          );
          // 敲門者自己收尾清掉那筆記錄
          allow delete: if isDormMember(dormId) && requesterUid == request.auth.uid;
        }
      }

      match /duties/{dutyId} {
        allow read, write: if isDormMember(dormId);
      }

      match /messages/{messageId} {
        // 公共頻道的訊息沒有 participants 欄位，大家都看得到；
        // 悄悄話一定要帶 participants(剛好兩個 uid)，只有裡面的人自己讀得到 ——
        // 篩選頻道只在畫面上做是不夠的，這裡才是真正擋住別人偷看悄悄話的地方。
        allow read: if isDormMember(dormId)
          && (!('participants' in resource.data) || request.auth.uid in resource.data.participants);
        allow create: if isDormMember(dormId)
          && request.resource.data.authorUid == request.auth.uid
          && (!('participants' in request.resource.data) || request.auth.uid in request.resource.data.participants);
        allow update, delete: if false;
      }

      match /actions/{actionId} {
        // 打招呼/攻擊某部位之類的小動作，一閃即逝的訊號，發送者自己可以刪掉
        allow read: if isDormMember(dormId);
        allow create: if isDormMember(dormId) && request.resource.data.fromUid == request.auth.uid;
        allow delete: if isDormMember(dormId) && resource.data.fromUid == request.auth.uid;
        allow update: if false;
      }

      match /pet/{petId} {
        allow read, write: if isDormMember(dormId);
      }
    }
  }
}
